version: 1.0

// 25 distinct saturated colors for each cell in the 5x5 grid
// Colors chosen to be visually distinct from each other
#colors palette {
  #FF0000 #FF8000 #FFFF00 #80FF00 #00FF00 #00FF80 #00FFFF #0080FF #0000FF #8000FF #FF00FF #FF0080 #804000 #408000 #008040 #004080 #400080 #800040 #808080 #C0C0C0 #400000 #004000 #000040 #404040 #000000
}

#divModDemo programmable() {
  pos: 0, 0
  grid: 1280, 720

  @alpha(0.1) bitmap(generated(color(1280, 720, white)));

  // Grid of 25 elements arranged 5x5 using div and mod
  // Row = $index div 5, Column = $index % 5
  // Each cell has a unique saturated color from the palette
  repeatable($index, step(25, dx: 0)) {
    pos: 20, 80
    bitmap(generated(colorWithText(60, 60, palette(colors, $index), $index, white, "dd"))): ($index % 5) * 80, ($index div 5) * 100
  }
}
