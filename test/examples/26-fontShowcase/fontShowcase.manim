version: 0.5

// =============================================================================
// FONT SHOWCASE - Using $ctx.font().lineHeight and .baseLine for layout
// =============================================================================
// Green rect = lineHeight * scale, Red line = baseLine
// =============================================================================

#fontShowcase programmable() {
    pos: 0, 0
    grid: 1280, 720

    // Dark background
    bitmap(generated(color(1280, 720, #222)));

    // Legend
    point {
        pos: 40, 12
        graphics(
            line(#FF4444, 2, 0, 6, 30, 6);
            rect(#44AA44, 1, 30, 14): 0, 18;
        );
        text(dd, "= baseLine", #FF4444, left, 200):34, 0;
        text(dd, "= lineHeight rect", #44AA44, left, 300):34, 16;
    }

    // =========================================================================
    // f3x5 font - scale 10x
    // =========================================================================
    point {
        pos: 40, 80
        @final lh = $ctx.font("f3x5").lineHeight
        @final bl = $ctx.font("f3x5").baseLine
        @final s = 10
        @final boxW = 400
        @final boxH = $lh * $s
        graphics(
            rect(#44AA44, 1, $boxW, $boxH): 0, 0;
            line(#FF4444, 2, 0, $bl * $s, $boxW, $bl * $s);
        );
        @scale(10) text(f3x5, "20HP/Ag0Wx", white, left, $boxW):0,0;
        text(dd, '  f3x5  lh:${$lh} bl:${$bl} @10x', #666, left, 400):5, $boxH + 5;
    }

    // =========================================================================
    // pixeled6 font - scale 10x
    // =========================================================================
    point {
        pos: 500, 80
        @final lh = $ctx.font("pixeled6").lineHeight
        @final bl = $ctx.font("pixeled6").baseLine
        @final s = 10
        @final boxW = 400
        @final boxH = $lh * $s
        graphics(
            rect(#44AA44, 1, $boxW, $boxH): 0, 0;
            line(#FF4444, 2, 0, $bl * $s, $boxW, $bl * $s);
        );
        @scale(10) text(pixeled6, "Ag0Wx", white, left, $boxW):0,0;
        text(dd, '  pixeled6  lh:${$lh} bl:${$bl} @10x', #666, left, 400):5, $boxH + 5;
    }

    // =========================================================================
    // m3x6 font - scale 10x
    // =========================================================================
    point {
        pos: 960, 80
        @final lh = $ctx.font("m3x6").lineHeight
        @final bl = $ctx.font("m3x6").baseLine
        @final s = 10
        @final boxW = 280
        @final boxH = $lh * $s
        graphics(
            rect(#44AA44, 1, $boxW, $boxH): 0, 0;
            line(#FF4444, 2, 0, $bl * $s, $boxW, $bl * $s);
        );
        @scale(10) text(m3x6, "Ag0Wx", white, left, $boxW):0,0;
        text(dd, '  m3x6  lh:${$lh} bl:${$bl} @10x', #666, left, 280):5, $boxH + 5;
    }

    // =========================================================================
    // pixellari font - scale 5x
    // =========================================================================
    point {
        pos: 40, 200
        @final lh = $ctx.font("pixellari").lineHeight
        @final bl = $ctx.font("pixellari").baseLine
        @final s = 5
        @final boxW = 400
        @final boxH = $lh * $s
        graphics(
            rect(#44AA44, 1, $boxW, $boxH): 0, 0;
            line(#FF4444, 2, 0, $bl * $s, $boxW, $bl * $s);
        );
        @scale(5) text(pixellari, "Ag0Wx", white, left, $boxW):0,0;
        text(dd, '  pixellari  lh:${$lh} bl:${$bl} @5x', #666, left, 400):5, $boxH + 5;
    }

    // =========================================================================
    // dd (digitaldisco) font - scale 5x
    // =========================================================================
    point {
        pos: 500, 200
        @final lh = $ctx.font("dd").lineHeight
        @final bl = $ctx.font("dd").baseLine
        @final s = 5
        @final boxW = 400
        @final boxH = $lh * $s
        graphics(
            rect(#44AA44, 1, $boxW, $boxH): 0, 0;
            line(#FF4444, 2, 0, $bl * $s, $boxW, $bl * $s);
        );
        @scale(5) text(dd, "20HP/xAg0", white, left, $boxW):0,5;
        text(dd, '  dd  lh:${$lh} bl:${$bl} @5x', #666, left, 400):5, $boxH + 5;
    }

    // =========================================================================
    // peaberry-white-outline on dark - scale 3x
    // =========================================================================
    point {
        pos: 40, 320
        @final lh = $ctx.font("peaberry-white-outline").lineHeight
        @final bl = $ctx.font("peaberry-white-outline").baseLine
        @final s = 3
        @final boxW = 400
        @final boxH = $lh * $s
        graphics(
            rect(#44AA44, 1, $boxW, $boxH): 0, 0;
            line(#FF4444, 2, 0, $bl * $s, $boxW, $bl * $s);
        );
        @scale(3) text(peaberry-white-outline, "xXg jkl 09", white, left, $boxW):0,0;
        text(dd, '  peaberry-white-outline  lh:${$lh} bl:${$bl} @3x', white, left, 400):5, $boxH + 5;
    }

    // =========================================================================
    // peaberry-white on dark - scale 3x
    // =========================================================================
    point {
        pos: 500, 320
        @final lh = $ctx.font("peaberry-white").lineHeight
        @final bl = $ctx.font("peaberry-white").baseLine
        @final s = 3
        @final boxW = 400
        @final boxH = $lh * $s
        graphics(
            rect(#44AA44, 1, $boxW, $boxH): 0, 0;
            line(#FF4444, 2, 0, $bl * $s, $boxW, $bl * $s);
        );
        @scale(3) text(peaberry-white, "xXg jkl 09", white, left, $boxW):0,0;
        text(dd, '  peaberry-white  lh:${$lh} bl:${$bl} @3x', white, left, 400):5, $boxH + 5;
    }

    // =========================================================================
    // pixeled6 sentence - scale 8x
    // =========================================================================
    point {
        pos: 40, 430
        @final lh = $ctx.font("pixeled6").lineHeight
        @final bl = $ctx.font("pixeled6").baseLine
        @final s = 8
        @final boxW = 1000
        @final boxH = $lh * $s
        graphics(
            rect(#44AA44, 1, $boxW, $boxH): 0, 0;
            line(#FF4444, 2, 0, $bl * $s, $boxW, $bl * $s);
        );
        @scale(8) text(pixeled6, "The quick brown fox xgx", white, left, $boxW):0,0;
        text(dd, '  pixeled6 sentence @8x  lh:${$lh} bl:${$bl}', #666, left, 400):5, $boxH + 5;
    }

    // =========================================================================
    // dd sentence - scale 5x
    // =========================================================================
    point {
        pos: 40, 540
        @final lh = $ctx.font("dd").lineHeight
        @final bl = $ctx.font("dd").baseLine
        @final s = 5
        @final boxW = 1200
        @final boxH = $lh * $s
        graphics(
            rect(#44AA44, 1, $boxW, $boxH): 0, 0;
            line(#FF4444, 2, 0, $bl * $s, $boxW, $bl * $s);
        );
        @scale(5) text(dd, "The quick brown fox jumps xgx", white, left, $boxW):0,0;
        text(dd, '  dd sentence @5x  lh:${$lh} bl:${$bl}', #666, left, 400):5, $boxH + 5;
    }

    // Info
    text(peaberry-white-outline, "Green rect = lineHeight * scale. Red line = baseLine.", #888, left, 800):40,660;
}
