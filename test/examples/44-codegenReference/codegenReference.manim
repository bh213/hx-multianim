version: 1.0

#codegenReferenceItem programmable(width:int, height:int, c1:color=white) {
  bitmap(generated(color($width, $height, $c1)));
}

#codegenReference programmable() {
  text(f3x5, "staticRef in codegen", #aaaaaa): 5, 3

  // Row 1: varied colors
  staticRef($codegenReferenceItem, width=>60, height=>40, c1=>#FF0000): 5, 14;
  staticRef($codegenReferenceItem, width=>60, height=>40, c1=>#00FF00): 75, 14;
  staticRef($codegenReferenceItem, width=>60, height=>40, c1=>#0000FF): 145, 14;
  staticRef($codegenReferenceItem, width=>60, height=>40, c1=>#FFFF00): 215, 14;

  // Row 2: varied sizes
  text(f3x5, "varied sizes:", #888888): 5, 60
  staticRef($codegenReferenceItem, width=>30, height=>30, c1=>#FF8844): 5, 72;
  staticRef($codegenReferenceItem, width=>80, height=>20, c1=>#44FF88): 45, 72;
  staticRef($codegenReferenceItem, width=>50, height=>50, c1=>#8844FF): 135, 72;
  staticRef($codegenReferenceItem, width=>100, height=>15, c1=>#FF44AA): 195, 72;

  // Row 3: large
  staticRef($codegenReferenceItem, width=>140, height=>45, c1=>#44AAFF): 5, 128;
  staticRef($codegenReferenceItem, width=>140, height=>45, c1=>#AAFF44): 155, 128;
}
