version: 1.0

layouts {
  #rowPos list {
    point: 10, 10
    point: 100, 10
    point: 190, 10
    point: 280, 10
    point: 370, 10
    point: 460, 10
  }

  #colPos list {
    point: 10, 80
    point: 10, 140
    point: 10, 200
    point: 10, 260
  }

  #diagPos list {
    point: 120, 80
    point: 200, 140
    point: 280, 200
    point: 360, 260
  }

  #zigzagPos list {
    point: 420, 80
    point: 480, 160
    point: 540, 80
    point: 570, 160
  }
}

#codegenGridPos programmable() {
  // Row: horizontal
  repeatable($i, layout("rowPos")) {
    bitmap(generated(color(80, 36, #4488FF))): 0, 0
    text(f3x5, $i, #ffffff): 35, 14
  }

  // Column: vertical
  repeatable($j, layout("colPos")) {
    bitmap(generated(color(80, 36, #FF4488))): 0, 0
    text(f3x5, $j, #ffffff): 35, 14
  }

  // Diagonal
  repeatable($k, layout("diagPos")) {
    bitmap(generated(color(60, 32, #44FF88))): 0, 0
    text(f3x5, $k, #ffffff): 25, 12
  }

  // Zigzag
  repeatable($z, layout("zigzagPos")) {
    bitmap(generated(color(60, 32, #FFAA44))): 0, 0
    text(f3x5, $z, #ffffff): 25, 12
  }
}
