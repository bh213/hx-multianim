version: 0.5

#codegenParticles programmable() {
    // Cone emitter (top-left)
    point {
        pos: 200, 200
        particles {
            count: 60
            emit: cone(0, 0, 270, 45)
            maxLife: 2.0
            speed: 120
            speedRandom: 0.3
            sizeRandom: 0.3
            lifeRandom: 0.3
            tiles: sheet("demo", "tile-center")
            loop: false
            size: 2.0
            gravity: 80
            gravityAngle: 90
            fadeOut: 0.7
            emitSync: 0.9
        }
    }

    // Point emitter (top-right)
    point {
        pos: 640, 200
        particles {
            count: 50
            emit: point(0, 0)
            maxLife: 1.5
            speed: 80
            speedRandom: 0.5
            sizeRandom: 0.4
            lifeRandom: 0.2
            tiles: sheet("demo", "tile-center")
            loop: false
            size: 1.5
            fadeOut: 0.6
            emitSync: 0.8
        }
    }

    // Box emitter (bottom)
    point {
        pos: 1000, 200
        particles {
            count: 40
            emit: box(100, 50, 0, 0)
            maxLife: 2.5
            speed: 60
            speedRandom: 0.2
            sizeRandom: 0.3
            lifeRandom: 0.3
            tiles: sheet("demo", "tile-center")
            loop: false
            size: 1.8
            gravity: 40
            gravityAngle: 90
            fadeOut: 0.5
            emitSync: 0.7
        }
    }
}
