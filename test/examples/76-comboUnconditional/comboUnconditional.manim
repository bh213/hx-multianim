version: 0.5

#comboBtn programmable(status:[hover, pressed, normal]=normal, disabled:[true, false]=false) {
    @(status=>normal, disabled=>false) bitmap(generated(color(120, 30, #446688))): 0, 0
    @(status=>hover, disabled=>false) bitmap(generated(color(120, 30, #5588aa))): 0, 0
    @(status=>pressed, disabled=>false) bitmap(generated(color(120, 30, #334455))): 0, 0
    @(status=>*, disabled=>true) bitmap(generated(color(120, 30, #555555))): 0, 0

    text(dd, "Always Visible", white, center, 120): 0, 8
    bitmap(generated(color(8, 8, #ff8800))): 5, 11
}

#comboUnconditional programmable() {
    text(dd, "Unconditional children in conditional programmables", #aaaaaa, left): 10, 10
    text(dd, "Orange square + text appear in ALL states (unconditional)", #888888, left): 10, 26

    text(dd, "status=>normal, disabled=>false", #666666, left): 140, 52
    staticRef($comboBtn, status=>normal, disabled=>false): 10, 50

    text(dd, "status=>hover, disabled=>false", #666666, left): 140, 92
    staticRef($comboBtn, status=>hover, disabled=>false): 10, 90

    text(dd, "status=>pressed, disabled=>false", #666666, left): 140, 132
    staticRef($comboBtn, status=>pressed, disabled=>false): 10, 130

    text(dd, "status=>normal, disabled=>true", #666666, left): 140, 172
    staticRef($comboBtn, status=>normal, disabled=>true): 10, 170

    text(dd, "status=>hover, disabled=>true", #666666, left): 140, 212
    staticRef($comboBtn, status=>hover, disabled=>true): 10, 210

    text(dd, "status=>pressed, disabled=>true", #666666, left): 140, 252
    staticRef($comboBtn, status=>pressed, disabled=>true): 10, 250

    // Legend
    text(dd, "#comboBtn: programmable with conditional backgrounds + unconditional text/icon", #888888, left): 10, 290
    text(dd, "Conditional: colored rect changes per status (blue/light/dark/grey)", #666666, left): 10, 306
    text(dd, "Unconditional: 'Always Visible' text + orange square stay in all states", #666666, left): 10, 322
}
