version: 0.5

layouts {
  #posLayout list {
    point: 10, 10
    point: 110, 10
    point: 210, 10
    point: 10, 80
    point: 110, 80
    point: 210, 80
  }
}

#layoutMultiChild programmable() {
  // Each iteration has multiple children: all should be at the SAME layout point.
  // Before the fix, the second child consumed the next layout point.
  repeatable($i, layout("main", "posLayout")) {
    pos: 0, 0
    bitmap(generated(color(80, 50, #FF44AA))): 0, 0
    bitmap(generated(color(60, 30, #44FFDD))): 10, 10
    bitmap(generated(color(30, 15, #FFFF44))): 25, 18
    text(f3x5, $i, #ffffff): 35, 20
  }
}
