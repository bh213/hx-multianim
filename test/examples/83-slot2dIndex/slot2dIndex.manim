version: 0.5

#slot2dIndex programmable() {
  text(f3x5, "2d indexed slots", #aaaaaa): 5, 3

  repeatable2d($x, $y, step(3, dx: 80), step(2, dy: 60)) {
    #cell[$x, $y] slot {
      @($x => 0) bitmap(generated(color(70, 50, #553333ff))): 0, 14
      @($x => 1) bitmap(generated(color(70, 50, #335533ff))): 0, 14
      @($x => 2) bitmap(generated(color(70, 50, #333355ff))): 0, 14
      text(f3x5, ""+$x+","+$y, #ffffffff): 5, 24
    }
  }
}
