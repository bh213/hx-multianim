    @(status=>focused)  ninepatch("ui", "Text_Grey_3x3_pressed", $width, $height): 0, 0
    @(status=>disabled) ninepatch("ui", "Text_Grey_3x3_disabled", $width, $height): 0, 0

    @(placeholder=>true) text(dd, $placeholderText, #888888): 4, 4

    #textArea point: 4, 4
}

