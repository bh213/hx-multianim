version: 0.5

#richText programmable() {

  // Row 1: Named styles (color only, color+font, font only)
  point {
    pos: 10, 30
    bitmap(generated(color(600, 40, #333)));
    @scale(2) richText(dd, "Deal [damage]50[/] for [gold]100g[/] [em]now[/]", white, left, 600,
        styles: {damage: color(#FF0000), gold: color(#FFD700) font("dd"), em: font("dd")}): 4, 4;
  }

  // Row 2: Named styles with named colors
  point {
    pos: 10, 80
    bitmap(generated(color(600, 40, #333)));
    @scale(2) richText(dd, "[fire]fire[/] [ice]ice[/] [nature]nature[/]", white, left, 600,
        styles: {fire: color(red), ice: color(cyan), nature: color(lime)}): 4, 4;
  }

  // Row 3: Multiple named styles with colors
  point {
    pos: 10, 130
    bitmap(generated(color(600, 40, #333)));
    @scale(2) richText(dd, "[warn]Warning:[/] costs [price]100g[/]", white, left, 600,
        styles: {warn: color(#FF4444), price: color(gold)}): 4, 4;
  }

  // Row 4: Nesting — style inside style
  point {
    pos: 10, 180
    bitmap(generated(color(600, 40, #333)));
    @scale(2) richText(dd, "[damage]crit [highlight]50[/] dmg[/]", white, left, 600,
        styles: {damage: color(#FF0000), highlight: color(yellow)}): 4, 4;
  }

  // Row 5: Inline image
  point {
    pos: 10, 230
    bitmap(generated(color(600, 40, #333)));
    @scale(2) richText(dd, "Cost [img:coin] 100 gold", white, left, 600,
        images: {coin: generated(color(14, 14, #FFD700))}): 4, 4;
  }

  // Row 6: Alignment markers
  point {
    pos: 10, 280
    bitmap(generated(color(300, 100, #333)));
    @scale(2) richText(dd, "left\n[align:center]center[/]\n[align:right]right[/]", white, left, 300): 4, 4;
  }

  // Row 7: condenseWhite
  point {
    pos: 330, 280
    bitmap(generated(color(300, 40, #333)));
    @scale(2) richText(dd, "spaces   condensed   here", white, left, 300,
        condenseWhite: true): 4, 4;
  }

  // Row 8: Plain text — no markup, still uses h2d.HtmlText
  point {
    pos: 10, 400
    bitmap(generated(color(600, 40, #333)));
    @scale(2) richText(dd, "plain text no markup", yellow, left, 600): 4, 4;
  }

  // Row 9: Hyperlinks
  point {
    pos: 10, 450
    bitmap(generated(color(600, 40, #333)));
    @scale(2) richText(dd, "Visit [link:shop][hl]the shop[/][/] or [link:inv][hl]inventory[/][/]", white, left, 600,
        styles: {hl: color(cyan)}): 4, 4;
  }
}
