version: 1.0

#pvComponent programmable() {
      placeholder(generated(cross(50, 20, #00FF00)), builderParameter("compNoSettings")):0,0
      placeholder(generated(cross(50, 20, #0000FF)), builderParameter("compWithSettings")) {
            settings{buildName=>gridCell, originX:float=>100, originY:float=>200}
            pos: 0, 30
      }
}
